{
  "name": "lexentia-vs",
  "displayName": "lexentia vs",
  "description": "ai coding assistant for vscode",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "machine-learning",
    "programming-languages",
    "debuggers"
  ],
  "activationEvents": [
    "*",
    "onCommand:lexentia.openChat",
    "onView:lexentia.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lexentia.openChat",
        "title": "open chat",
        "category": "lexentia"
      },
      {
        "command": "lexentia.explainLine",
        "title": "explain line",
        "category": "lexentia"
      },
      {
        "command": "lexentia.fixLine",
        "title": "fix line",
        "category": "lexentia"
      },
      {
        "command": "lexentia.newTerminal",
        "title": "new terminal",
        "category": "lexentia"
      },
      {
        "command": "lexentia.exportAuditLog",
        "title": "export audit log",
        "category": "lexentia"
      },
      {
        "command": "lexentia.exportAiActions",
        "title": "export ai actions timeline",
        "category": "lexentia"
      },
      {
        "command": "lexentia.toggleAuditLog",
        "title": "toggle audit logging",
        "category": "lexentia"
      },
      {
        "command": "lexentia.toggleAutocomplete",
        "title": "toggle autocomplete",
        "category": "lexentia"
      },
      {
        "command": "lexentia.inlineEdit",
        "title": "inline edit",
        "category": "lexentia"
      }
    ],
    "views": {
      "lexentia": [
        {
          "type": "webview",
          "id": "lexentia.sidebar",
          "name": "chat",
          "when": "true"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lexentia",
          "title": "lexentia",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "lexentia.explainLine",
          "group": "lexentia@1",
          "when": "editorHasSelection"
        },
        {
          "command": "lexentia.fixLine",
          "group": "lexentia@2",
          "when": "editorHasSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "lexentia.inlineEdit",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "lexentia",
      "properties": {
        "lexentia.models": {
          "type": "array",
          "default": [
            {
              "provider": "ollama",
              "model": "llama3.1",
              "apiKey": "",
              "apiBaseUrl": "http://127.0.0.1:11434"
            }
          ],
          "description": "array of model configurations"
        },
        "lexentia.roles.chat": {
          "type": "string",
          "default": "0",
          "description": "index of model for chat (complex reasoning, >32k context)"
        },
        "lexentia.roles.autocomplete": {
          "type": "string",
          "default": "0",
          "description": "index of model for autocomplete (low latency, FIM support)"
        },
        "lexentia.roles.embeddings": {
          "type": "string",
          "default": "0",
          "description": "index of model for embeddings"
        },
        "lexentia.autocomplete.enabled": {
          "type": "boolean",
          "default": true,
          "description": "enable tab autocomplete"
        },
        "lexentia.autocomplete.debounceMs": {
          "type": "number",
          "default": 250,
          "description": "debounce delay in milliseconds for autocomplete"
        },
        "lexentia.autocomplete.maxContextTokens": {
          "type": "number",
          "default": 2000,
          "description": "maximum context tokens for autocomplete"
        },
        "lexentia.rag.chunkSize": {
          "type": "number",
          "default": 750,
          "description": "chunk size for RAG indexing (tokens)"
        },
        "lexentia.rag.chunkOverlap": {
          "type": "number",
          "default": 100,
          "description": "chunk overlap for RAG indexing (tokens)"
        },
        "lexentia.rag.vectorStore": {
          "type": "string",
          "enum": ["memory", "sqlite"],
          "default": "memory",
          "description": "vector store backend for RAG"
        },
        "lexentia.security.localOnly": {
          "type": "boolean",
          "default": false,
          "description": "use only local models (Ollama)"
        },
        "lexentia.security.disableTelemetry": {
          "type": "boolean",
          "default": true,
          "description": "disable all telemetry and external data sending"
        },
        "lexentia.customCommands": {
          "type": "array",
          "default": [
            {
              "name": "refactor",
              "prompt": "Refactor this code to improve readability and performance."
            },
            {
              "name": "test",
              "prompt": "Generate unit tests for this code."
            },
            {
              "name": "explain",
              "prompt": "Explain this code in detail."
            }
          ],
          "description": "custom slash commands with their prompts"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "20.x",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0"
  }
}
